# ─────────────────────────────────────────────────────
# 📂 File Opening Configuration
# ─────────────────────────────────────────────────────
cmd open ${{
    case "$f" in
        # Media files
        *.mp4|*.mkv|*.avi|*.webm|*.mov|*.flv) mpv --fs --no-border "$f" ;;
        
        # Images
        *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.svg) sxiv -t "$f" ;;
        
        # Documents
        *.pdf|*.djvu|*.epub) zathura "$f" ;;
        
        # Archives
        *.zip|*.tar|*.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.rar|*.7z) 
            xdg-open "$f" ;;
        
        # Office documents
        *.docx|*.odt|*.doc|*.xls|*.xlsx|*.ods|*.ppt|*.pptx|*.odp) 
            libreoffice "$f" ;;
        
        # Web files
        *.html|*.htm) firefox "$f" ;;
        
        # Code files - open with VS Code
        *.py|*.js|*.jsx|*.ts|*.tsx|*.c|*.cpp|*.h|*.hpp|*.java|*.go|*.rs|*.php|*.rb|*.sh|*.bash|*.css|*.scss|*.json|*.md|*.yaml|*.yml|*.toml|*.conf)
            code "$f" ;;
        
        # Text files - open with VS Code or use bat for preview
        *.txt|*.md|*.markdown|*.log)
            if [ -n "$DISPLAY" ]; then
                code "$f"
            else
                bat --style=numbers --color=always "$f"
            fi ;;
        
        # Default handler
        *) 
            if [ -d "$f" ]; then
                lf -remote "send $id cd \"$f\""
            else
                xdg-open "$f"
            fi ;;
    esac
}}

