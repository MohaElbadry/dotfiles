# Extract various archive formats
cmd extract ${{
    case "$f" in
        *.tar.gz|*.tgz)     tar -xvzf "$f" ;;
        *.tar.bz2|*.tbz2)   tar -xvjf "$f" ;;
        *.tar.xz|*.txz)     tar -xvJf "$f" ;;
        *.tar)              tar -xvf "$f" ;;
        *.zip)              unzip "$f" ;;
        *.rar)              unrar x "$f" ;;
        *.7z)               7z x "$f" ;;
        *)                  echo "Unsupported format" ;;
    esac
}}

# Create a new file
cmd touch ${{
    touch "$@"
    lf -remote "send $id select \"$@\""
}}

# Create a new directory
cmd mkdir ${{
    mkdir -p "$@"
    lf -remote "send $id select \"$@\""
}}

# Bulk rename files using $EDITOR
cmd bulkrename ${{
    tmpfile=$(mktemp)
    ls -N --quoting-style=literal | cat -n > "$tmpfile"
    $EDITOR "$tmpfile"
    
    if [ $(wc -l < "$tmpfile") -ne $(ls | wc -l) ]; then
        echo "Number of lines changed. Cancelled."
        rm -f "$tmpfile"
        return
    fi
    
    while read -r line; do
        num=$(echo "$line" | cut -f1)
        name=$(echo "$line" | cut -f2-)
        [ -n "$name" ] && [ "$name" != "$(ls -N --quoting-style=literal | sed "${num}q;d")" ] &&
        mv "$(ls -N --quoting-style=literal | sed "${num}q;d")" "$name"
    done < "$tmpfile"
    
    rm -f "$tmpfile"
    lf -remote "send $id reload"
}}

# File information
